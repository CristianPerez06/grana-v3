{
  "name": "mobile",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "dev": "expo start --dev-client",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "build:android": "eas build --profile production --platform android",
    "build:android:local": "eas build --profile production --platform android --local",
    "build:ios": "eas build --profile production --platform ios",
    "build:ios:local": "eas build --profile production --platform ios --local",
    "build:list": "eas build:list --limit 5"
  },
  "dependencies": {
    "@expo-google-fonts/plus-jakarta-sans": "^0.4.2",
    "@grana/dashboard": "workspace:*",
    "@grana/money-logic": "workspace:*",
    "@grana/supabase": "workspace:*",
    "@grana/ui-contracts": "workspace:*",
    "@grana/validation": "workspace:*",
    "@tanstack/react-query": "5.100.13",
    "expo": "~54.0.33",
    "expo-constants": "~18.0.13",
    "expo-font": "~14.0.11",
    "expo-linking": "~8.0.12",
    "expo-router": "~6.0.23",
    "expo-secure-store": "^55.0.14",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "lucide-react-native": "^1.16.0",
    "nativewind": "^4.2.4",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-css-interop": "^0.2.4",
    "react-native-reanimated": "~4.1.7",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-worklets": "0.8.3"
  },
  "devDependencies": {
    "@grana/ui-tokens": "workspace:*",
    "@types/react": "~19.1.0",
    "babel-preset-expo": "~54.0.10",
    "eas-cli": "^18.13.0",
    "eslint": "^9.39.4",
    "eslint-config-expo": "^55.0.1",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.9.2"
  },
  "private": true
}
