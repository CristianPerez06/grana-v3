public-hoist-pattern[]=*eslint*
public-hoist-pattern[]=*next*

# Required by Expo + React Native in pnpm monorepos.
# RN libraries (Reanimated, etc.) run Node scripts during Gradle/Xcode
# builds that resolve sibling packages via require.resolve(). pnpm's
# default isolated linker breaks those resolutions. Hoisted gives a
# flat npm-style layout that works for RN and is harmless for Next.
# https://docs.expo.dev/guides/monorepos/#pnpm
node-linker=hoisted
